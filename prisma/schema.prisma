generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id           String              @id @default(cuid())
  name         String
  initials     String
  color        String
  imageUrl     String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  competitions CompetitionPlayer[]
  awayMatches  Match[]             @relation("AwayPlayer")
  homeMatches  Match[]             @relation("HomePlayer")
}

model Competition {
  id            String              @id @default(cuid())
  name          String
  slug          String              @unique
  status        String              @default("REGISTRATION")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  celebrationAt DateTime?
  players       CompetitionPlayer[]
  journees      Journee[]
  knockoutTies  KnockoutTie[]
}

model CompetitionPlayer {
  id            String      @id @default(cuid())
  competitionId String
  playerId      String
  rank          Int?
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([competitionId, playerId])
}

model Journee {
  id            String      @id @default(cuid())
  number        Int
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  matches       Match[]

  @@unique([competitionId, number])
}

model Match {
  id           String    @id @default(cuid())
  journeeId    String
  homePlayerId String
  awayPlayerId String
  homeScore    Int?
  awayScore    Int?
  status       String    @default("PENDING")
  playedAt     DateTime?
  updatedAt    DateTime  @updatedAt
  awayPlayer   Player    @relation("AwayPlayer", fields: [awayPlayerId], references: [id])
  homePlayer   Player    @relation("HomePlayer", fields: [homePlayerId], references: [id])
  journee      Journee   @relation(fields: [journeeId], references: [id], onDelete: Cascade)
}

/// A knockout tie. For two-legged rounds (ROUND_OF_16, SEMIFINAL) we use
/// leg1 and leg2 score fields. For the FINAL (single leg) we use leg1 only.
/// playerA hosts leg1, playerB hosts leg2 (returns inverted).
model KnockoutTie {
  id            String      @id @default(cuid())
  competitionId String
  round         String
  slot          Int
  twoLegged     Boolean     @default(true)
  playerAId     String?
  playerBId     String?
  leg1HomeScore Int?
  leg1AwayScore Int?
  leg2HomeScore Int?
  leg2AwayScore Int?
  etHomeScore   Int?
  etAwayScore   Int?
  penA          Int?
  penB          Int?
  status        String      @default("PENDING")
  drawnAt       DateTime?
  updatedAt     DateTime    @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([competitionId, round, slot])
}
